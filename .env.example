# JARVIS Environment Variables
# Copy to .env and fill in your values. Never commit .env.

# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── STT ──────────────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=...

# ── Wake Word ─────────────────────────────────────────────────────────────────
PICOVOICE_ACCESS_KEY=...

# ── TTS ──────────────────────────────────────────────────────────────────────
CARTESIA_API_KEY=...
CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091   # replace with your voice ID
# ELEVENLABS_API_KEY=...     # fallback
# ELEVENLABS_VOICE_ID=...

# ── Search ────────────────────────────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=...     # preferred
# SERPER_API_KEY=...         # alternative

# ── Finance ───────────────────────────────────────────────────────────────────
ALPACA_API_KEY=...
ALPACA_SECRET_KEY=...

# ── Health ────────────────────────────────────────────────────────────────────
OURA_PERSONAL_TOKEN=...

# ── Smart Home ────────────────────────────────────────────────────────────────
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=...

# ── Remote API ────────────────────────────────────────────────────────────────
JARVIS_API_SECRET=your-strong-random-secret-here
JARVIS_API_PORT=8765

# ── Push Notifications ────────────────────────────────────────────────────────
# ntfy.sh (free, recommended) — install ntfy app, subscribe to your topic
NTFY_TOPIC=jarvis-alerts          # your chosen topic name
# NTFY_URL=https://ntfy.sh       # override for self-hosted ntfy

# Pushover (alternative) — requires account at pushover.net
# PUSHOVER_API_TOKEN=...
# PUSHOVER_USER_KEY=...

# Generic webhook (advanced)
# PUSH_WEBHOOK_URL=https://your-endpoint.com/jarvis-alerts
